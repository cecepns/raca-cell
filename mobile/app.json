{
  "expo": {
    "name": "Raca Cell",
    "slug": "raca-cell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.racacell.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.racacell.app"
    },
    "extra": {
      "eas": {
        "projectId": "raca-cell-mobile"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
